PORT=8000
ENVIRONMENT=production

# Model artefact paths
MODEL_PATH=models/churn_model.pkl
SCALER_PATH=models/scaler.pkl

# CORS — restrict to your S3 static site URL in production
ALLOWED_ORIGINS=https://your-bucket.s3-website.us-east-1.amazonaws.com

# AWS deployment targets
AWS_REGION=us-east-1
ECR_REPOSITORY=churniq-api
LAMBDA_FUNCTION_NAME=churniq-function
S3_BUCKET_NAME=churniq-frontend-prod